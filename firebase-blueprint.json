{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "number" },
        "apiProvider": { "type": "string", "enum": ["finnhub", "twelvedata", "alphavantage", "polygon", "fmp", "marketstack", "iexcloud", "cryptocompare", "coingecko", "coinmarketcap", "eodhistoricaldata", "barchart", "custom"] },
        "apiKey": { "type": "string" },
        "customApiUrl": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Alert": {
      "title": "Alert",
      "description": "A price alert set by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "targetPrice": { "type": "number" },
        "condition": { "type": "string", "enum": ["above", "below"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "triggeredAt": { "type": "number" }
      },
      "required": ["userId", "symbol", "targetPrice", "condition", "isActive"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Price alerts"
    }
  }
}
